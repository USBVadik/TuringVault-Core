{
  "enabled": false,
  "name": "Auto Format Code",
  "description": "Автоматически запускает Prettier после редактирования JS/TS файлов для поддержания консистентного стиля кода",
  "version": "1",
  "when": {
    "type": "fileEdited",
    "patterns": [
      "**/*.ts",
      "**/*.tsx",
      "**/*.js",
      "**/*.jsx"
    ]
  },
  "then": {
    "type": "runCommand",
    "command": "npx prettier --write \"$KIRO_FILE_PATH\"",
    "timeout": 30
  }
}
# TuringVault Environment Configuration
# Copy this file to .env and fill in your values

# ═══ BLOCKCHAIN ═══
MANTLE_RPC_URL=https://rpc.mantle.xyz
MANTLE_SEPOLIA_RPC_URL=https://rpc.sepolia.mantle.xyz
PRIVATE_KEY=your_wallet_private_key_here

# ═══ AI MODELS ═══
# GLM-5 via Tencent Cloud / AWS Bedrock
AWS_ACCESS_KEY_ID=your_aws_key
AWS_SECRET_ACCESS_KEY=your_aws_secret
AWS_REGION=us-east-1

# Evolved prompts gate (T7, agent-reasoning-quality)
# When 'true', the analyst loads its prompt from IPFS (auto-mutated based on
# settlement outcomes) and appends a non-evolvable FORMAT_GUARD_SUFFIX. When
# 'false' or unset, the static ANALYST_SYSTEM_PROMPT in multiAgent.js is used.
# Default off until 50-cycle smoke confirms parse rate ≥ 95%.
EVOLVED_PROMPTS_ENABLED=false

# Optional: declare how the agent is being run, surfaced via /api/health.mode
# Values: manual | cron-github-actions | cron-vps | unknown (default unknown)
AGENT_RUN_MODE=manual

# ═══ DATA PROVIDERS ═══
NANSEN_API_KEY=your_nansen_mcp_key

# ═══ IPFS (Proof-of-Reasoning storage) ═══
PINATA_API_KEY=your_pinata_key
PINATA_SECRET=your_pinata_secret
PINATA_JWT=your_pinata_jwt

# ═══ DEPLOYMENT (optional) ═══
VERCEL_TOKEN=your_vercel_token
